{
  "name": "@mcps/communication",
  "version": "0.1.0",
  "description": "MCP hub para delegar tarefas entre Cursor, Antigravity e Copilot",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "mcpcomunication": "dist/index.js"
  },
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "dev": "tsx --watch src/index.ts",
    "mcp:dev": "tsx watch --clear-screen=false src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.0",
    "@supabase/supabase-js": "^2.108.2",
    "undici": "^7.22.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
