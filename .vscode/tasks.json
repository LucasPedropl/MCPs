{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Servidor Web",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/apps/servidor-web"
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Ready|started|compiled"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "serverReadyAction": {
        "pattern": "Ready|started",
        "uriFormat": "http://localhost:3000",
        "action": "openExternally"
      }
    },
    {
      "label": "Start Servidor API",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/apps/servidor-api"
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^.*$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "rodando perfeitamente|ERRO"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Start Supabase Hub (MCP)",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/packages/supabase-hub"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Start Communication (MCP)",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/packages/communication"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    },
    {
      "label": "Start Servidor (Web + API)",
      "dependsOn": ["Start Servidor API", "Start Servidor Web"],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
