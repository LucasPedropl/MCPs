{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Agent OS Dashboard",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/apps/servidor-web"
      },
      "isBackground": true,
      "problemMatcher": {
        "pattern": { "regexp": "^.*$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Ready|started|compiled"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "serverReadyAction": {
        "pattern": "Ready|started",
        "uriFormat": "http://localhost:3000/agent-os",
        "action": "openExternally"
      }
    }
  ]
}
