{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Terminal: Agent OS Dashboard (Next.js)",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run dev",
      "cwd": "${workspaceFolder}/apps/servidor-web",
      "presentation": {
        "group": "mcp",
        "panel": "dedicated",
        "reveal": "always"
      }
    },
    {
      "name": "Terminal: openapi-engine (SSE opcional)",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run start -- --sse",
      "cwd": "${workspaceFolder}/packages/openapi-engine",
      "presentation": {
        "group": "mcp",
        "panel": "dedicated",
        "reveal": "always"
      }
    },
    {
      "name": "Abrir Dashboard no navegador",
      "type": "node-terminal",
      "request": "launch",
      "command": "node -e \"setTimeout(() => require('child_process').exec('start http://localhost:3000/agent-os'), 3000)\"",
      "cwd": "${workspaceFolder}",
      "presentation": {
        "reveal": "never",
        "panel": "shared"
      }
    }
  ],
  "compounds": [
    {
      "name": "Agent OS Dashboard",
      "configurations": [
        "Terminal: Agent OS Dashboard (Next.js)",
        "Abrir Dashboard no navegador"
      ]
    }
  ]
}
