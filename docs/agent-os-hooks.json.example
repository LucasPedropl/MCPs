{
  "$comment": "Hooks do Cursor para o Agent OS. Copie para ~/.cursor/hooks.json (global) ou <projeto>/.cursor/hooks.json. Ajuste o caminho do dist. Credenciais: os hooks leem AGENT_OS_SUPABASE_* do env, de ~/.agent-os/hooks-env.json ou do ~/.cursor/mcp.json (env do servidor agent-os).",
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "node C:/codigo/pessoal/MCPs/packages/agent-os/dist/hooks/hook-cli.js context",
        "timeout": 15
      }
    ],
    "beforeShellExecution": [
      {
        "command": "node C:/codigo/pessoal/MCPs/packages/agent-os/dist/hooks/hook-cli.js enforce-shell",
        "timeout": 10,
        "failClosed": false
      }
    ],
    "preToolUse": [
      {
        "command": "node C:/codigo/pessoal/MCPs/packages/agent-os/dist/hooks/hook-cli.js enforce-write",
        "matcher": "Write|Edit|StrReplace|MultiEdit|Delete",
        "timeout": 10,
        "failClosed": false
      }
    ]
  }
}
