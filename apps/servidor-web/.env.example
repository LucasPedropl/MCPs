# Supabase (obrigatório para dashboard Agent OS)
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key

# Opcional: gateway SSE legado (openapi-engine --sse)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Opcional: segredo HMAC do cookie de sessão (se omitido, usa SERVICE_ROLE_KEY)
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DASHBOARD_SESSION_SECRET=

# Login email/senha: criar usuário no Supabase Auth (Dashboard → Authentication → Users)
# Não use DASHBOARD_EMAIL / DASHBOARD_PASSWORD — credenciais ficam no Auth.
